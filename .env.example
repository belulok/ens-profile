DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production HTTPS behind nginx + certbot:
# CSRF_TRUSTED_ORIGINS=https://your.domain.com
# USE_X_FORWARDED_PROTO=True

# For local dev, leave empty to use SQLite at ./db.sqlite3
# For production, set to your Postgres URL:
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Ethereum RPC endpoint (PublicNode is free + keyless + reliable)
# Alternatives: https://eth.merkle.io  https://eth.drpc.org
RPC_URL=https://ethereum.publicnode.com
